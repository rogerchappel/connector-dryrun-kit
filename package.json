{
  "name": "connector-dryrun-kit",
  "version": "0.1.0",
  "description": "Local-first connector action dry-run receipts for agent workflows.",
  "type": "module",
  "bin": {
    "connector-dryrun": "./bin/connector-dryrun.js"
  },
  "scripts": {
    "check": "node --check bin/connector-dryrun.js && node --check src/index.js",
    "lint": "npm run check",
    "test": "node --test",
    "smoke": "node bin/connector-dryrun.js fixtures/sample-plan.json --format markdown",
    "validate": "bash scripts/validate.sh",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run lint && npm run test && npm run smoke && npm run validate && npm run package:smoke"
  },
  "keywords": [
    "agents",
    "connector",
    "dry-run",
    "approval",
    "skill"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "fixtures",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "examples",
    "scripts",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/connector-dryrun-kit.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/connector-dryrun-kit/issues"
  },
  "homepage": "https://github.com/rogerchappel/connector-dryrun-kit#readme"
}
